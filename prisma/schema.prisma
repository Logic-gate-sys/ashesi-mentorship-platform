
generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}



enum Role {
  STUDENT
  ALUMNI
  ADMIN
}

enum Industry {
  TECHNOLOGY
  FINANCE
  CONSULTING
  HEALTHCARE
  EDUCATION
  ENGINEERING
  OTHER
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum MessageType {
  TEXT
  FILE
  SYSTEM
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  firstName    String
  lastName     String
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // one-to-one profile per role
  studentProfile StudentProfile?
  alumniProfile  AlumniProfile?

  // messaging
  sentMessages     Message[] @relation("SentMessages")
  conversations    ConversationParticipant[]

  // notifications
  notifications Notification[]

  @@index([email])
  @@index([role])
}

model StudentProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  yearGroup Int
  major     String
  bio       String?
  linkedin  String?
  interests String[]   // e.g. ["Fintech", "Machine Learning"]

  // requests this student has sent
  requests MentorshipRequest[]

  // sessions this student attended
  sessions Session[]

  @@index([major])
}

model AlumniProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  graduationYear Int
  major          String
  company        String
  jobTitle       String
  industry       Industry
  bio            String?
  linkedin       String?
  skills         String[]    // e.g. ["React", "System Design"]
  isAvailable    Boolean  @default(true)

  // requests received by this alumni
  requests      MentorshipRequest[]

  // sessions this alumni hosted
  sessions      Session[]

  // weekly availability slots
  availability  Availability[]

  @@index([industry])
  @@index([major])
  @@index([isAvailable])
}

model MentorshipRequest {
  id        String        @id @default(uuid())
  status    RequestStatus @default(PENDING)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  alumniId  String
  alumni    AlumniProfile  @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  goal      String         // min 20 chars, max 500
  message   String?        // optional personal note, max 1000 chars

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  resolvedAt DateTime?

  // a request, once accepted, leads to sessions
  sessions Session[]

  @@unique([studentId, alumniId, status])   // one pending request per pair
  @@index([studentId])
  @@index([alumniId])
  @@index([status])
}


model Session {
  id        String        @id @default(uuid())
  status    SessionStatus @default(SCHEDULED)

  requestId String
  request   MentorshipRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  alumniId  String
  alumni    AlumniProfile  @relation(fields: [alumniId], references: [id])

  topic       String
  notes       String?
  scheduledAt DateTime
  duration    Int          // minutes
  meetingUrl  String?

  feedback    SessionFeedback?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([alumniId])
  @@index([scheduledAt])
  @@index([status])
}

model SessionFeedback {
  id        String  @id @default(uuid())
  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  rating    Int     // 1–5
  comment   String?

  createdAt DateTime @default(now())
}

model Availability {
  id        String   @id @default(uuid())
  alumniId  String
  alumni    AlumniProfile @relation(fields: [alumniId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  startTime String    // "09:00"
  endTime   String    // "11:00"

  @@unique([alumniId, dayOfWeek, startTime])
  @@index([alumniId])
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  lastReadAt DateTime?

  @@unique([conversationId, userId])
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  type    MessageType @default(TEXT)
  body    String
  fileUrl String?

  createdAt DateTime @default(now())

  @@index([conversationId, createdAt])
}


model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "REQUEST_RECEIVED" | "REQUEST_ACCEPTED" | "SESSION_REMINDER" etc.
  title     String
  body      String
  isRead    Boolean  @default(false)
  link      String?  // "/sessions/abc" — deep link in the app

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@index([createdAt])
}

