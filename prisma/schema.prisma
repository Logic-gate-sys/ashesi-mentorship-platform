generator client {
  provider = "prisma-client"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---

enum Role {
  MENTOR
  MENTEE
  ADMIN
}

enum NotificationType {
  NEW_MESSAGE
  REQUEST_UPDATE
  SESSION_REMINDER
  SYSTEM_ANNOUNCEMENT
}

enum Industry {
  TECHNOLOGY
  FINANCE
  CONSULTING
  HEALTHCARE
  EDUCATION
  ENGINEERING
  ART_AND_DESIGN
  MANUFACTURING
  OTHER
}

enum RequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum SessionStatus {
  SCHEDULED
  COMPLETED
  CANCELLED
  RESCHEDULED
  NO_SHOW
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum MessageType {
  TEXT
  FILE
  IMAGE
}

enum CycleStatus {
  PLANNING
  REGISTRATION_OPEN
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum MeetingType {
  VIRTUAL
  IN_PERSON
}

// ############################## MODELS ##############################################
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role
  firstName    String
  lastName     String
  avatarUrl    String?
  isVerified   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Profiles
  mentorProfile MentorProfile?
  menteeProfile MenteeProfile?

  // Social / Communications
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")
  notifications    Notification[]
  messages         Message[]

  @@index([email])
  @@index([role])
}

model MenteeProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  yearGroup Int
  major     String
  bio       String?  @db.Text
  linkedin  String?
  interests String[]

  requests MentorshipRequest[]
  sessions Session[]

  @@index([major])
}

model MentorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  graduationYear Int
  major          String
  company        String
  jobTitle       String
  industry       Industry
  bio            String?  @db.Text
  linkedin       String?
  skills         String[]

  isAvailable Boolean @default(true)
  maxMentees  Int     @default(2) // Limit mentor workload

  requests     MentorshipRequest[]
  sessions     Session[]
  availability Availability[]

  @@index([industry])
  @@index([isAvailable])
}

model MentorshipCycle {
  id                    String              @id @default(uuid())
  name                  String // e.g., "Fall 2026 Cohort"
  status                CycleStatus         @default(PLANNING)
  description           String?             @db.Text
  startDate             DateTime
  endDate               DateTime
  registrationOpenDate  DateTime?
  registrationCloseDate DateTime?
  requests              MentorshipRequest[] // Track which requests belong to which cycle
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([status, id])
}

model MentorshipRequest {
  id         String          @id @default(uuid())
  status     RequestStatus   @default(PENDING)
  menteeId   String
  mentee     MenteeProfile   @relation(fields: [menteeId], references: [id], onDelete: Cascade)
  mentorId   String
  mentor     MentorProfile   @relation(fields: [mentorId], references: [id], onDelete: Cascade)
  cycleId    String
  cycle      MentorshipCycle @relation(fields: [cycleId], references: [id])
  goal       String          @db.Text
  message    String?         @db.Text
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  resolvedAt DateTime?
  sessions   Session[]

  @@unique([menteeId, mentorId, cycleId]) // Prevent multiple requests in the same cycle
  @@index([menteeId])
  @@index([mentorId])
}

model Session {
  id          String            @id @default(uuid())
  status      SessionStatus     @default(SCHEDULED)
  type        MeetingType       @default(VIRTUAL)
  requestId   String
  request     MentorshipRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  menteeId    String
  mentee      MenteeProfile     @relation(fields: [menteeId], references: [id])
  mentorId    String
  mentor      MentorProfile     @relation(fields: [mentorId], references: [id])
  topic       String
  notes       String?           @db.Text
  scheduledAt DateTime
  duration    Int // minutes
  meetingUrl  String? // Zoom/Google Meet link

  feedback  SessionFeedback?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@index([menteeId])
  @@index([mentorId])
  @@index([scheduledAt])
}

model SessionFeedback {
  id        String   @id @default(uuid())
  sessionId String   @unique
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  rating    Int // 1–5
  comment   String?  @db.Text
  createdAt DateTime @default(now())
}

model Availability {
  id       String        @id @default(uuid())
  mentorId String
  mentor   MentorProfile @relation(fields: [mentorId], references: [id], onDelete: Cascade)

  dayOfWeek DayOfWeek
  startTime String // "HH:mm" format
  endTime   String

  @@unique([mentorId, dayOfWeek, startTime])
}

model Conversation {
  id        String    @id @default(uuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             String        @id @default(uuid())
  senderId       String
  receiverId     String
  type           MessageType   @default(TEXT)
  body           String        @db.Text
  fileUrl        String? // if type is file
  createdAt      DateTime      @default(now())
  sender         User          @relation("SentMessages", fields: [senderId], references: [id])
  receiver       User          @relation("ReceivedMessages", fields: [receiverId], references: [id])
  user           User?         @relation(fields: [userId], references: [id])
  userId         String?
  conversation   Conversation? @relation(fields: [conversationId], references: [id])
  conversationId String?
}

//email notification 
model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  body      String
  path      String? // e.g., "/dashboard/requests/123"
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
}
